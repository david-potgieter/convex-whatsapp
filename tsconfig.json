{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "paths": {
      "convex-webhook-receiver/_generated/component.js": [
        "./node_modules/convex-webhook-receiver/src/component/_generated/component.ts"
      ]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/component/_generated", "node_modules", "dist"]
}
