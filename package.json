{
  "name": "convex-whatsapp",
  "version": "1.1.5",
  "description": "Convex component for the WhatsApp Cloud API — send & receive messages, track delivery, and manage conversations reactively.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev:codegen": "bunx convex codegen --component-dir ./src/component --watch",
    "dev:build": "tsup --watch",
    "dev": "bunx convex dev",
    "build": "tsup",
    "build:full": "bunx convex codegen --component-dir ./src/component && tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "changesets": "changeset",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./convex.config": {
      "types": "./src/component/convex.config.ts",
      "import": "./dist/convex.config.js"
    },
    "./_generated/component": "./src/component/_generated/component.ts",
    "./test": "./src/test.ts"
  },
  "files": [
    "dist",
    "src/component/_generated/component.ts",
    "src/test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/david-potgieter/convex-whatsapp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "convex": ">=1.40.0"
  },
  "dependencies": {
    "convex-webhook-receiver": "latest"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@edge-runtime/vm": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "convex-test": "latest",
    "husky": "^9.1.7",
    "tsup": "latest",
    "typescript": "^5.7.2",
    "vitest": "latest"
  }
}
